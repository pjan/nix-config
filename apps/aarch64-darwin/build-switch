#!/usr/bin/env bash
set -eo pipefail

GREEN="$(printf '\033[1;32m')"
YELLOW="$(printf '\033[1;33m')"
NC="$(printf '\033[0m')"

SYSTEM_TYPE="aarch64-darwin"
FLAKE_SYSTEM="darwinConfigurations.${SYSTEM_TYPE}.system"

export NIXPKGS_ALLOW_UNFREE=1

keep_result=false
forward_args=()
nix_args=(--extra-experimental-features 'nix-command flakes')

for arg in "$@"; do
  if [[ "$arg" == "--keep-result" ]]; then
    keep_result=true
  else
    forward_args+=("$arg")
  fi
done

# Skip build if result already exists (e.g. from a prior nix run .#build --keep-result)
if [[ ! -L ./result ]]; then
  echo "${YELLOW}Starting build...${NC}"
  nix "${nix_args[@]}" build "path:.#${FLAKE_SYSTEM}" "${forward_args[@]}"
fi

RESULT="$(readlink -f ./result)"

echo "${YELLOW}Switching to new generation...${NC}"
# Activate directly from the pre-built result, bypassing flake re-evaluation.
# darwin-rebuild switch does exactly: nix-env --set the profile, then run activate.
sudo nix-env --profile /nix/var/nix/profiles/system --set "$RESULT"
if [[ -r "${SSL_CERT_FILE_PATH}" ]]; then
  sudo env \
    NIX_SSL_CERT_FILE="${SSL_CERT_FILE_PATH}" \
    SSL_CERT_FILE="${SSL_CERT_FILE_PATH}" \
    NIX_CONFIG="ssl-cert-file = ${SSL_CERT_FILE_PATH}" \
    "$RESULT/activate"
else
  sudo "$RESULT/activate"
fi

if [[ "$keep_result" == true ]]; then
  echo "${YELLOW}Keeping result symlink...${NC}"
else
  echo "${YELLOW}Cleaning up...${NC}"
  unlink ./result
fi

echo "${GREEN}Switch to new generation complete!${NC}"
