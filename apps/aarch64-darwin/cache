#!/usr/bin/env bash
set -euo pipefail

GREEN="$(printf '\033[1;32m')"
YELLOW="$(printf '\033[1;33m')"
RED="$(printf '\033[1;31m')"
NC="$(printf '\033[0m')"

nix_args=(--extra-experimental-features 'nix-command flakes')

# AWS SDK C++ 1.11.x+ adds CRC64NVME checksums to streaming uploads by default.
# GCS S3-compatible API rejects these with 403. Disable proactive checksums.
export AWS_REQUEST_CHECKSUM_CALCULATION=when_required
export AWS_RESPONSE_CHECKSUM_VALIDATION=when_required

if [[ ! -L ./result ]]; then
  echo "${RED}No ./result symlink found. Run nix run .#build --keep-result first.${NC}"
  exit 1
fi

echo "${YELLOW}Storing result in remote cache...${NC}"
nix "${nix_args[@]}" store sign --recursive -k /etc/nix/secret-key "$(readlink ./result)"
nix "${nix_args[@]}" copy --to "s3://io-vandaele-nix-cache?endpoint=https://storage.googleapis.com&profile=gcp" "$(readlink result)"

echo "${GREEN}Copy to cache complete!${NC}"
